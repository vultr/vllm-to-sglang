ARG BASE_IMAGE=lmsysorg/sglang-rocm:v0.5.11-rocm720-mi30x-20260508

FROM ${BASE_IMAGE}

COPY --from=ghcr.io/astral-sh/uv:0.11.11 /uv /uvx /bin/

RUN apt-get update && \
    apt-get install -y --no-install-recommends haproxy patch && \
    rm -rf /var/lib/apt/lists/*

# Apply local patches to AITER before installing. See
# docs/aiter.md "Upstream patches" for the rationale. Every patch in
# docker/sglang/patches/ is applied in sorted name order; --dry-run
# runs first so an AITER bump that breaks any patch fails the image
# build loudly instead of silently producing a half-patched image.
# Capture AITER's commit SHA to /etc/vllm-shim/aiter-cache-key so the
# shim can namespace AITER's JIT .so cache by AITER version at
# runtime: bumping the pinned AITER tag rotates the namespace and
# AITER recompiles from the new source instead of silently loading
# a stale .so from the PV. See vllm_shim.cli.rocm_perf._aiter_cache_key
# for the read side, and docs/aiter.md "JIT cache namespacing by
# AITER commit" for the rationale (incl. the deliberate decision not
# to also hash the patches dir).
COPY docker/sglang/patches/ /tmp/patches/
RUN cd /sgl-workspace/aiter && \
    for p in $(find /tmp/patches -type f -name '*.patch' | sort); do \
        patch --dry-run -p1 < "$p" && patch -p1 < "$p" || exit 1; \
    done && \
    mkdir -p /etc/vllm-shim && \
    git -C /sgl-workspace/aiter rev-parse --short=12 HEAD \
        > /etc/vllm-shim/aiter-cache-key && \
    rm -rf /tmp/patches

# AMD's aiter kernels belong with SGLang in its existing 3.10 venv.
RUN uv pip install --no-cache --python /opt/venv/bin/python /sgl-workspace/aiter

# Install transformers from upstream main into SGLang's venv, past both the
# base image's pinned version and the latest PyPI release, so newer model
# architectures (Kimi K2.6 etc.) and fixes for them are available without
# waiting on a release cycle.
RUN uv pip install --no-cache --python /opt/venv/bin/python \
        --upgrade git+https://github.com/huggingface/transformers.git

# vllm-shim lives in its own Python 3.12 venv so it can satisfy
# requires-python without disturbing SGLang's 3.10 environment. The launcher
# spawns SGLang via the `sglang` console script in /opt/venv/bin; the script's
# shebang routes execution back into SGLang's 3.10 interpreter, so the two
# environments do not need to share a sys.path.
RUN uv venv /opt/shim --python 3.12

COPY pyproject.toml uv.lock /src/
COPY packages /src/packages
RUN uv pip install --no-cache --python /opt/shim/bin/python \
        /src/packages/vllm-shim \
        /src/packages/vllm-entrypoints

# /opt/shim/bin first so `vllm` resolves to our entrypoint;
# /opt/venv/bin so the launcher can resolve `sglang`.
ENV PATH="/opt/shim/bin:/opt/venv/bin:${PATH}"
