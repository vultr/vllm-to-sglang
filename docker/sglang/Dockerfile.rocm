ARG BASE_IMAGE=lmsysorg/sglang-rocm:v0.5.11-rocm720-mi30x-20260508

FROM ${BASE_IMAGE}

COPY --from=ghcr.io/astral-sh/uv:0.11.11 /uv /uvx /bin/

RUN apt-get update && \
    apt-get install -y --no-install-recommends haproxy && \
    rm -rf /var/lib/apt/lists/*

# Bump bundled Triton past PR #9646 ("[AMD] Use common path for gfx942
# scaled dot emulation", merged 2026-03-13) so tl.dot_scaled lowers to
# BF16 MFMA on gfx942. The base image pins Triton at a Jan 15 2026
# commit that predates CDNA3 scaled-dot support; without this bump
# every AITER FP4 Triton kernel (gemm_afp4wfp4, moe_op_mxfp4*,
# fused_gemm_afp4wfp4_*, batched_gemm_afp4wfp4) hits "Unsupported
# DotScaleOp found when converting TritonGPU to LLVM" during the
# first MXFP4 forward. TRITON_COMMIT is upstream Triton main HEAD at
# the time the bump was authored (2026-05-13); pristine upstream
# Triton, just newer than what the base image happened to pin. See
# docs/aiter.md "Triton MXFP4 on MI300X" for the broader story.
#
# This build sits ahead of the patch-apply step on purpose: it depends
# only on the base image and the two ARGs below, never on patches/, so
# editing a patch no longer invalidates this (expensive, multi-minute)
# layer. The rebuild then only triggers on a base-image or ARG change.
ARG TRITON_COMMIT=d3156632257bc363a12716facc7f92f55428815f
# MAX_JOBS caps Ninja parallelism. Triton's setup.py defaults to
# 2 * cpu_count() concurrent C++ jobs; MLIR/LLVM translation units peak
# at 1-2GB+ each, so the default OOM-kills the build daemon on a
# memory-constrained builder (e.g. a 32GB WSL2 VM). 8 keeps peak
# compile memory under that ceiling at the cost of wall time.
ARG MAX_JOBS=8
RUN cd /sgl-workspace/triton-custom && \
    git fetch origin --quiet && \
    git -c advice.detachedHead=false checkout ${TRITON_COMMIT} && \
    rm -rf build python/build && \
    MAX_JOBS=${MAX_JOBS} \
    uv pip install --no-cache --python /opt/venv/bin/python --no-build-isolation -e .

# Apply local patches to AITER and SGLang before installing. See
# docs/aiter.md "Upstream patches" for the rationale, and
# scripts/apply-patches.sh for the branch model. Patches live at
# patches/<repo>/[<tier>/] at the repo root; scripts/apply-patches.sh
# replays them onto the upstream checkout as a stack of commits on
# patched/<platform>. A base-image bump that breaks any patch fails
# the image build loudly (via git am) instead of silently producing a
# half-patched image. Capture AITER's post-patch HEAD to
# /etc/vllm-shim/aiter-cache-key so the shim can namespace AITER's
# JIT .so cache by AITER+patches version at runtime: bumping AITER
# OR editing a patch rotates the cache namespace and AITER recompiles
# from the new source instead of silently loading a stale .so from
# the PV. See vllm_shim.cli.rocm_perf.aiter_cache_key for the read
# side, and docs/aiter.md "JIT cache namespacing by AITER commit"
# for the rationale.
COPY patches/ /tmp/patches/
COPY scripts/ /tmp/scripts/
RUN bash /tmp/scripts/apply-patches.sh aiter  rocm /sgl-workspace/aiter  && \
    bash /tmp/scripts/apply-patches.sh sglang rocm /sgl-workspace/sglang && \
    mkdir -p /etc/vllm-shim && \
    git -C /sgl-workspace/aiter rev-parse --short=12 HEAD \
        > /etc/vllm-shim/aiter-cache-key && \
    rm -rf /tmp/patches /tmp/scripts

# AMD's aiter kernels belong with SGLang in its existing 3.10 venv.
RUN uv pip install --no-cache --python /opt/venv/bin/python /sgl-workspace/aiter

# Install transformers from upstream main into SGLang's venv, past both the
# base image's pinned version and the latest PyPI release, so newer model
# architectures (Kimi K2.6 etc.) and fixes for them are available without
# waiting on a release cycle.
RUN uv pip install --no-cache --python /opt/venv/bin/python \
        --upgrade git+https://github.com/huggingface/transformers.git

# vllm-shim lives in its own Python 3.12 venv so it can satisfy
# requires-python without disturbing SGLang's 3.10 environment. The launcher
# spawns SGLang via the `sglang` console script in /opt/venv/bin; the script's
# shebang routes execution back into SGLang's 3.10 interpreter, so the two
# environments do not need to share a sys.path.
RUN uv venv /opt/shim --python 3.12

COPY pyproject.toml uv.lock /src/
COPY packages /src/packages
RUN uv pip install --no-cache --python /opt/shim/bin/python \
        /src/packages/vllm-shim \
        /src/packages/vllm-entrypoints

# /opt/shim/bin first so `vllm` resolves to our entrypoint;
# /opt/venv/bin so the launcher can resolve `sglang`.
ENV PATH="/opt/shim/bin:/opt/venv/bin:${PATH}"
