From f3b5176c5f427423b3b69e92cf04bae9b4a1cd1d Mon Sep 17 00:00:00 2001
From: vllm-shim <vllm-shim@local>
Date: Thu, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH 1/2] perf(gradlib): bound hipBLASLt candidate sweep via
 heuristic API

The aiter tuner currently sweeps every hipBLASLt algorithm for each
shape via `hipblaslt_ext::getAllAlgos`. On MI300X that's ~1365
candidates per shape, all unranked: the surviving
`matmulIsAlgoSupported` filter only checks workspace fit, not
predicted perf. The tuner then benchmarks every candidate, which is
slow and includes algorithms that GPU-fault on specific shape
geometries (the same root cause the mp_tuner patch papers over).

This patch swaps the call for `hipblasLtMatmulAlgoGetHeuristic`, the
API that uses the full matmul descriptor (m/n/k, layouts, bias,
scaling) to filter and rank candidates by predicted performance. It
also restores the supporting `preference` and `returnedAlgoCount`
locals that the original code had removed alongside the heuristic
call (still visible commented-out one line above).

The candidate cap is exposed via `AITER_MAX_GEMM_CANDIDATES`. Default
10 matches the value the commented-out original code used; set 2048
to recover the full-sweep behaviour for comparison runs.

No known upstream PR; the shim's images carry this locally until
upstream restores the heuristic call or exposes an equivalent knob.
---
 gradlib/csrc/hipbsolgemm.cu | 42 ++++++++++++++++++++++++-------------
 1 file changed, 27 insertions(+), 15 deletions(-)

diff --git a/gradlib/csrc/hipbsolgemm.cu b/gradlib/csrc/hipbsolgemm.cu
index 455bbc4..97c8f58 100644
--- a/gradlib/csrc/hipbsolgemm.cu
+++ b/gradlib/csrc/hipbsolgemm.cu
@@ -230,21 +230,33 @@ std::vector<int> hipblasLtMatmul_findallsols_wrapper(hipblasLtHandle_t handle,
             matmul, HIPBLASLT_MATMUL_DESC_D_SCALE_POINTER, &scaleC, sizeof(scaleC)));
     }
 
-    // std::vector<hipblasLtMatmulHeuristicResult_t> heuristicResult(10);
-    // CHECK_HIPBLAS_ERROR(hipblasLtMatmulAlgoGetHeuristic(
-    //     handle, matmul, matA, matB, matC, matC,
-    //     preference, 10, heuristicResult.data(), &returnedAlgoCount));
-    std::vector<hipblasLtMatmulHeuristicResult_t> heuristicResult;
-    CHECK_HIPBLAS_ERROR(hipblaslt_ext::getAllAlgos(handle,
-                                                   hipblaslt_ext::GemmType::HIPBLASLT_GEMM,
-                                                   op_A,
-                                                   op_B,
-                                                   intype,
-                                                   intype,
-                                                   outtype,
-                                                   outtype,
-                                                   HIPBLAS_COMPUTE_32F,
-                                                   heuristicResult));
+    // vllm-shim patch: use hipBLASLt's matmul heuristic to get the
+    // top-N ranked algorithms for this specific shape/dtype/layout
+    // instead of the full ~1365 candidates from getAllAlgos. The
+    // heuristic uses the matmul descriptor (m/n/k, layouts, bias,
+    // scaling) to filter and rank; benchmarking ranked candidates
+    // for each shape avoids the long tail of algos that fault on
+    // specific geometries. Cap is configurable via env var so an
+    // operator can dial it without rebuilding the image.
+    int max_candidates = 10;
+    if (const char* env = std::getenv("AITER_MAX_GEMM_CANDIDATES")) {
+        int parsed = std::atoi(env);
+        if (parsed > 0) {
+            max_candidates = parsed;
+        }
+    }
+    hipblasLtMatmulPreference_t preference;
+    CHECK_HIPBLAS_ERROR(hipblasLtMatmulPreferenceCreate(&preference));
+    CHECK_HIPBLAS_ERROR(hipblasLtMatmulPreferenceSetAttribute(
+        preference, HIPBLASLT_MATMUL_PREF_MAX_WORKSPACE_BYTES,
+        &workspace_size, sizeof(workspace_size)));
+    std::vector<hipblasLtMatmulHeuristicResult_t> heuristicResult(max_candidates);
+    int returnedAlgoCount = 0;
+    CHECK_HIPBLAS_ERROR(hipblasLtMatmulAlgoGetHeuristic(
+        handle, matmul, matA, matB, matC, matC,
+        preference, max_candidates, heuristicResult.data(), &returnedAlgoCount));
+    heuristicResult.resize(returnedAlgoCount);
+    CHECK_HIPBLAS_ERROR(hipblasLtMatmulPreferenceDestroy(preference));
 
     std::vector<int> algoIndex;
     int returned_algo_count = heuristicResult.size();
