@@ -81,6 +81,18 @@ _DUMP_EP_AFTER = int(os.environ.get("VLLM_SHIM_MXFP4_DUMP_EP_AFTER", "0"))
 _DUMP_EP_RUNS = int(os.environ.get("VLLM_SHIM_MXFP4_DUMP_EP_RUNS", "1"))
 _ep_dump_counts: dict = {}
 
+# Per-layer post-MoE hidden-state dump for head-to-head EP vs non-EP diffing.
+# Gated by VLLM_SHIM_MOE_POST_DUMP=N (default 0 = disabled). Fires on the
+# first N eager forwards per (layer_id, mode) pair where mode is "ep" or
+# "nonep". Operator runs the same prompt once in EP and once in non-EP;
+# each run produces one line per (layer, call) with an abs_mean/abs_max/
+# l2/first-row signature. Diffing the two logs by (layer_id, call_n) shows
+# where (if anywhere) the EP and non-EP post-MoE outputs diverge. Layer 0
+# should match within bf16 noise; the first layer where they don't is
+# where the bug lives.
+_POST_DUMP = int(os.environ.get("VLLM_SHIM_MOE_POST_DUMP", "0"))
+_post_dump_counts: dict = {}
+
 
 def _load_triton_ops():
     global _triton_ops_loaded, _fused_moe_mxfp4, _fused_moe_mxfp4_silu
@@ -432,6 +444,42 @@ def triton_mxfp4_moe(
     return ws.output
 
 
+def maybe_dump_post_moe(layer_id, mode: str, hidden_states: torch.Tensor) -> None:
+    """Per-layer post-MoE hidden-state summary for EP vs non-EP head-to-head.
+
+    Called by MoriEPMoE.forward (post-combine) and QuarkW4A4MXFp4MoE.apply_weights
+    (post-triton_mxfp4_moe in the non-EP fallback). Both call sites land at the
+    same semantic point: the MoE layer's contribution to the residual stream for
+    this rank's tokens. With the same prompt and the same DP layout, the two
+    runs should agree to bf16 noise on every layer. The first layer where they
+    don't is where the EP integration drifts from the math non-EP performs.
+    """
+    if _POST_DUMP <= 0 or _is_capturing():
+        return
+    key = (int(layer_id), mode)
+    n = _post_dump_counts.get(key, 0)
+    if n >= _POST_DUMP:
+        return
+    _post_dump_counts[key] = n + 1
+    try:
+        h = hidden_states.detach()
+        n_tokens = int(h.shape[0])
+        h_fp32 = h.float()
+        first_row = h[0, :8].to("cpu").tolist() if n_tokens > 0 else []
+        logger.error(
+            "[POST-MOE call=%d] layer=%d mode=%s n_tokens=%d "
+            "abs_mean=%.5f abs_max=%.5f l2=%.5f first_row[:8]=%s",
+            n, int(layer_id), mode, n_tokens,
+            h_fp32.abs().mean().item(),
+            h_fp32.abs().max().item(),
+            h_fp32.norm().item(),
+            [f"{v:+.5f}" for v in first_row],
+        )
+    except Exception as e:  # noqa: BLE001
+        logger.error("[POST-MOE call=%d] layer=%d mode=%s failed: %r",
+                     n, int(layer_id), mode, e)
+
+
 def _is_capturing() -> bool:
     # is_current_stream_capturing exists on PyTorch 2.0+; guard for older.
     fn = getattr(torch.cuda, "is_current_stream_capturing", None)
