From 17207a8d427e9f1b3c6d6314b573425035564204 Mon Sep 17 00:00:00 2001
From: vllm-shim <vllm-shim@local>
Date: Thu, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH 8/8] fix(quark): route MoRI EP MXFP4 align through
 moe_sorting_opus_fwd

The [SORT-DUMP] diagnostic showed moe_sorting_fwd (CK variant) writing
encoded values into sorted_token_ids instead of plain flat indices on
7 of 8 DPs:

  DP1 sorted_token_ids[:32] = [0x01000000, 0x01000001, ..., 0x0100001f]
  DP2 sorted_token_ids[:32] = [0, 1, 2, ..., 31]
  DP3 sorted_token_ids[:32] = [0x02000000, ...]
  DP4/6/7 sorted_token_ids[:32] = [0x08000000, ...]

The Triton GEMM masks via ``offs_token < num_valid_tokens`` (= M*top_k
= 294912 = 0x48000). Every garbage value is far above the mask
threshold, so every write is skipped and triton output is identically
zero (matches the verify pattern exactly: mean_diff == ref_abs_mean
across 7 of 8 DPs, only DP2 with the small values produces non-zero
output).

The base image's CK moe_sorting_fwd appears to use this encoding for
its own CK GEMM kernels (which are compile-time excluded on gfx942
anyway). The opus variant of moe_sorting is a rewrite outside CK;
attempt switching to it in the hope it emits plain flat indices.

Calls moe_sorting_opus_fwd with the same 12-arg signature the base
image's binding exports (per the prior backout in 'use moe_sorting_fwd,
not opus' commit message: the base image has 12-arg opus_fwd without
the workspace-getter symbol, repos/aiter drifted ahead to a 13-arg
variant that needs a separate workspace tensor). Falls back to the CK
variant if the opus binding isn't present.
---
 .../quark/schemes/triton_mxfp4_dispatch.py    | 33 ++++++++++++-------
 1 file changed, 22 insertions(+), 11 deletions(-)

diff --git a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
index 7ddd866..e7e717a 100644
--- a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
+++ b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
@@ -66,15 +66,23 @@ def _load_triton_ops():
         _moe_align_block_size_stage4_kernel,
     )
 
-    # MoRI EP path only. moe_sorting_fwd is the block-align primitive
-    # AITER's own fused_moe uses by default; it does the global->local
-    # expert remap from expert_mask that the SGLang Triton align kernels
-    # cannot. Its module .so ships prebuilt in the base image, so the
-    # first call is a dlopen rather than a JIT compile. It allocates its
-    # sort scratch internally, but the size is a pure function of the
-    # (static) dispatch dims, so that allocation lands in the CUDA-graph
-    # pool cleanly during capture.
-    from aiter.ops.moe_sorting import moe_sorting_fwd
+    # MoRI EP path only. Use moe_sorting_opus_fwd (12-arg signature in
+    # the base image, no workspace) rather than moe_sorting_fwd. The CK
+    # moe_sorting_fwd in the base image writes a non-trivial encoding
+    # into sorted_token_ids (the [SORT-DUMP] diagnostic showed values
+    # like 0x01000000+i instead of plain flat indices, which the Triton
+    # GEMM's ``offs_token < num_valid_tokens`` mask rejects, producing
+    # all-zero output for 7 of 8 DPs). The opus variant is the same
+    # block-align primitive but rewritten outside CK; the hope is that
+    # it emits plain flat indices the Triton kernel can consume. Falls
+    # back to moe_sorting_fwd if the opus binding isn't present in the
+    # base image (older AITER builds may lack it).
+    try:
+        from aiter.ops.moe_sorting_opus import moe_sorting_opus_fwd as _sort_fn
+        _sort_name = "moe_sorting_opus_fwd"
+    except ImportError:
+        from aiter.ops.moe_sorting import moe_sorting_fwd as _sort_fn
+        _sort_name = "moe_sorting_fwd"
 
     _fused_moe_mxfp4 = fused_moe_mxfp4
     _fused_moe_mxfp4_silu = fused_moe_mxfp4_silu
@@ -84,9 +92,12 @@ def _load_triton_ops():
         _moe_align_block_size_stage3_kernel,
         _moe_align_block_size_stage4_kernel,
     )
-    _moe_sorting_fwd = moe_sorting_fwd
+    _moe_sorting_fwd = _sort_fn
     _triton_ops_loaded = True
-    logger.info("Loaded Triton MXFP4 MoE kernels for gfx942 fallback")
+    logger.info(
+        "Loaded Triton MXFP4 MoE kernels for gfx942 fallback (sort=%s)",
+        _sort_name,
+    )
 
 
 _STAGE1_CONFIG = {
