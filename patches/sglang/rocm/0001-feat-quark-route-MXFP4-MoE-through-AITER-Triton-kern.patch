@@ -0,0 +1,230 @@
+"""Triton MXFP4 MoE dispatch for gfx942 (MI300X).
+
+Bypasses AITER's fused_moe() dispatcher (which routes to CK kernels
+that are compile-time excluded on gfx942) and calls AITER's Triton
+MXFP4 MoE kernels directly. The Triton kernels use tl.dot_scaled,
+which decomposes FP4 ops into BF16 upcast + BF16 MFMA on gfx942.
+
+CUDA-graph-capture safe: all GPU tensors are pre-allocated in a
+workspace cache on the first (warmup) call and reused on subsequent
+calls. No torch.tensor/empty/zeros/full calls happen after warmup,
+which is the property graph capture needs.
+
+Called from QuarkW4A4MXFp4MoE.apply_weights when
+``_use_triton_mxfp4_fallback`` is set (AITER enabled and not gfx95).
+The companion MoRI EP integration lives in ep_moe/layer.py and is
+gated separately on SGLANG_MORI_MXFP4_TRITON; non-EP can be
+validated in isolation first.
+"""
+
+import logging
+from types import SimpleNamespace
+from typing import Optional
+
+import torch
+import triton.language as tl
+
+logger = logging.getLogger(__name__)
+
+_triton_ops_loaded = False
+_fused_moe_mxfp4 = None
+_fused_moe_mxfp4_silu = None
+_align_kernels = None
+
+
+def _load_triton_ops():
+    global _triton_ops_loaded, _fused_moe_mxfp4, _fused_moe_mxfp4_silu
+    global _align_kernels
+    if _triton_ops_loaded:
+        return
+    from aiter.ops.triton.moe.moe_op_mxfp4 import fused_moe_mxfp4
+    from aiter.ops.triton.moe.moe_op_mxfp4_silu_fused import fused_moe_mxfp4_silu
+    from aiter.ops.triton._triton_kernels.moe.moe_align_block_size import (
+        _moe_align_block_size_stage1_kernel,
+        _moe_align_block_size_stage2_kernel,
+        _moe_align_block_size_stage3_kernel,
+        _moe_align_block_size_stage4_kernel,
+    )
+
+    _fused_moe_mxfp4 = fused_moe_mxfp4
+    _fused_moe_mxfp4_silu = fused_moe_mxfp4_silu
+    _align_kernels = (
+        _moe_align_block_size_stage1_kernel,
+        _moe_align_block_size_stage2_kernel,
+        _moe_align_block_size_stage3_kernel,
+        _moe_align_block_size_stage4_kernel,
+    )
+    _triton_ops_loaded = True
+    logger.info("Loaded Triton MXFP4 MoE kernels for gfx942 fallback")
+
+
+_STAGE1_CONFIG = {
+    "BLOCK_SIZE_M": 64,
+    "BLOCK_SIZE_N": 128,
+    "BLOCK_SIZE_K": 128,
+    "GROUP_SIZE_M": 8,
+}
+_STAGE2_CONFIG = {
+    "BLOCK_SIZE_M": 64,
+    "BLOCK_SIZE_N": 128,
+    "BLOCK_SIZE_K": 128,
+    "GROUP_SIZE_M": 8,
+}
+_BLOCK_M = 64
+
+
+def _ceil_div(a, b):
+    return (a + b - 1) // b
+
+
+_workspace_cache: dict = {}
+
+
+def _get_workspace(M, top_k, num_experts, hidden_dim, inter_dim, device, dtype):
+    key = (M, top_k, num_experts, hidden_dim, inter_dim, device)
+    if key in _workspace_cache:
+        return _workspace_cache[key]
+
+    num_valid = M * top_k
+    max_padded = num_valid + num_experts * _BLOCK_M - top_k
+    max_blocks = _ceil_div(max_padded, _BLOCK_M)
+
+    ws = SimpleNamespace(
+        num_valid=num_valid,
+        max_padded=max_padded,
+        max_blocks=max_blocks,
+        a_scale=torch.tensor(1.0, dtype=torch.float32, device=device),
+        b13_scale=torch.ones(num_experts, dtype=torch.float32, device=device),
+        b2_scale=torch.ones(num_experts, dtype=torch.float32, device=device),
+        sorted_token_ids=torch.empty(max_padded, dtype=torch.int32, device=device),
+        expert_ids=torch.empty(max_blocks, dtype=torch.int32, device=device),
+        num_tokens_post_padded=torch.empty(1, dtype=torch.int32, device=device),
+        tokens_cnts=torch.empty(
+            (num_experts + 1, num_experts), dtype=torch.int32, device=device
+        ),
+        cumsum=torch.empty(num_experts + 1, dtype=torch.int32, device=device),
+        stage1_out=torch.empty(max_padded, inter_dim, dtype=dtype, device=device),
+        stage2_out=torch.empty(1, max_padded, hidden_dim, dtype=dtype, device=device),
+        stage2_topk_weights=torch.empty(
+            max_padded, 1, dtype=torch.float32, device=device
+        ),
+        output=torch.empty(M, hidden_dim, dtype=dtype, device=device),
+    )
+    _workspace_cache[key] = ws
+    logger.info(
+        "Allocated MXFP4 MoE workspace: M=%d top_k=%d max_padded=%d device=%s",
+        M,
+        top_k,
+        max_padded,
+        device,
+    )
+    return ws
+
+
+def _moe_align_block_size_capture_safe(topk_ids, num_experts, block_size, ws):
+    numel = topk_ids.numel()
+    tokens_per_thread = _ceil_div(numel, num_experts)
+    grid = (num_experts,)
+    k1, k2, k3, k4 = _align_kernels
+
+    ws.tokens_cnts.zero_()
+    ws.cumsum.zero_()
+
+    k1[grid](topk_ids, ws.tokens_cnts, num_experts, numel, tokens_per_thread)
+    k2[grid](ws.tokens_cnts, num_experts)
+    k3[(1,)](
+        ws.num_tokens_post_padded,
+        ws.tokens_cnts,
+        ws.cumsum,
+        num_experts,
+        block_size,
+    )
+    k4[grid](
+        topk_ids,
+        ws.sorted_token_ids,
+        ws.expert_ids,
+        ws.tokens_cnts,
+        ws.cumsum,
+        num_experts,
+        block_size,
+        numel,
+        tokens_per_thread,
+    )
+
+
+def triton_mxfp4_moe(
+    hidden_states: torch.Tensor,
+    w13_weight: torch.Tensor,
+    w2_weight: torch.Tensor,
+    w13_weight_scale: torch.Tensor,
+    w2_weight_scale: torch.Tensor,
+    topk_weights: torch.Tensor,
+    topk_ids: torch.Tensor,
+    expert_mask: Optional[torch.Tensor] = None,
+) -> torch.Tensor:
+    _load_triton_ops()
+
+    M, hidden_dim = hidden_states.shape
+    top_k = topk_ids.shape[1]
+    num_experts = w13_weight.shape[0]
+    inter_dim = w13_weight.shape[1] // 2
+    device = hidden_states.device
+    dtype = hidden_states.dtype
+    num_valid_tokens = M * top_k
+
+    ws = _get_workspace(M, top_k, num_experts, hidden_dim, inter_dim, device, dtype)
+
+    ws.sorted_token_ids.fill_(num_valid_tokens)
+    _moe_align_block_size_capture_safe(topk_ids, num_experts, _BLOCK_M, ws)
+
+    ws.stage1_out.zero_()
+    _fused_moe_mxfp4_silu(
+        A=hidden_states,
+        B=w13_weight,
+        C=ws.stage1_out,
+        A_scale=ws.a_scale,
+        B_scale=ws.b13_scale,
+        A_mx_scale=None,
+        B_mx_scale=w13_weight_scale,
+        topk_weights=topk_weights,
+        topk_ids=topk_ids,
+        sorted_token_ids=ws.sorted_token_ids,
+        expert_ids=ws.expert_ids,
+        num_tokens_post_padded=ws.num_tokens_post_padded,
+        mul_routed_weight=False,
+        top_k=top_k,
+        swizzle_mx_a=False,
+        swizzle_mx_b=False,
+        config=_STAGE1_CONFIG,
+        compute_type=tl.bfloat16,
+    )
+
+    ws.stage2_out.zero_()
+    flat_weights = topk_weights.reshape(-1)
+    ws.stage2_topk_weights.zero_()
+    ws.stage2_topk_weights[:num_valid_tokens, 0] = flat_weights
+    _fused_moe_mxfp4(
+        A=ws.stage1_out,
+        B=w2_weight,
+        C=ws.stage2_out,
+        A_scale=ws.a_scale,
+        B_scale=ws.b2_scale,
+        A_mx_scale=None,
+        B_mx_scale=w2_weight_scale,
+        topk_weights=ws.stage2_topk_weights,
+        topk_ids=topk_ids,
+        sorted_token_ids=ws.sorted_token_ids,
+        expert_ids=ws.expert_ids,
+        num_tokens_post_padded=ws.num_tokens_post_padded,
+        mul_routed_weight=True,
+        top_k=1,
+        swizzle_mx_a=False,
+        swizzle_mx_b=False,
+        config=_STAGE2_CONFIG,
+        compute_type=tl.bfloat16,
+    )
+
+    stage2_flat = ws.stage2_out.squeeze(0)
+    valid_out = stage2_flat[:num_valid_tokens].view(M, top_k, hidden_dim)
+    torch.sum(valid_out, dim=1, out=ws.output)
+    return ws.output
