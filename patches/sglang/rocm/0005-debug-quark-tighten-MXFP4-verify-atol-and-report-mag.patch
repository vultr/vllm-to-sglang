From f83f3dbadfa8c8e87424f0374409335ee3c57322 Mon Sep 17 00:00:00 2001
From: vllm-shim <vllm-shim@local>
Date: Thu, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH 5/8] debug(quark): tighten MXFP4 verify atol and report
 magnitudes

The original atol=0.5 was set when per-row diffs of ~0.1 looked like
"bf16 vs fp32 reference noise". They aren't: bf16 precision for O(1)
values is ~2^-8 ~= 0.004, so 0.1 is an order of magnitude above the
bf16 floor. The verify kept reporting OK while the 60-layer residual
stream compounded the per-row error into the multilingual decode
garbage. Drop the default to 0.02 (a few ULPs at bf16 for values of a
few units, the band where a clean MoE computation should land) and
double max_rows to 64 so we sample more of the dispatch buffer.

Also widen the diagnostic surface: report mean_diff and ref_abs_mean
on both OK and FAIL so the operator can judge relative magnitude
(0.01 on values averaging 0.005 is catastrophic; on values averaging
5.0 it's noise).
---
 .../quark/schemes/triton_mxfp4_dispatch.py    | 28 ++++++++++++++++---
 1 file changed, 24 insertions(+), 4 deletions(-)

diff --git a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
index 2790674..217f2ea 100644
--- a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
+++ b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
@@ -41,8 +41,14 @@ _moe_sorting_fwd = None
 # chained call pattern is novel to this patch). Reports go to ERROR-level
 # logging so they land in stderr alongside the existing [aiter] / SGLang lines.
 _VERIFY = os.environ.get("VLLM_SHIM_MXFP4_VERIFY", "0") == "1"
-_VERIFY_ATOL = float(os.environ.get("VLLM_SHIM_MXFP4_VERIFY_ATOL", "0.5"))
-_VERIFY_MAX_ROWS = int(os.environ.get("VLLM_SHIM_MXFP4_VERIFY_MAX_ROWS", "32"))
+# Tightened from 0.5 -> 0.02. The original 0.5 was set after observing per-row
+# errors at ~0.1 and assuming bf16 intermediate rounding accounted for the
+# noise; in practice 0.1 is an order of magnitude above the bf16 floor for
+# values around O(1), and the 60-layer residual stream compounds it into the
+# decode garbage we saw. 0.02 is a few ULPs at bf16 precision for values of a
+# few units -- the band where a clean MoE computation should land.
+_VERIFY_ATOL = float(os.environ.get("VLLM_SHIM_MXFP4_VERIFY_ATOL", "0.02"))
+_VERIFY_MAX_ROWS = int(os.environ.get("VLLM_SHIM_MXFP4_VERIFY_MAX_ROWS", "64"))
 _verified_keys: set = set()
 
 
@@ -415,21 +421,35 @@ def _maybe_verify(
     ref_valid = ref_out[:n_check].to(torch.float32)
     diff = (triton_valid - ref_valid).abs()
     max_diff = diff.max().item()
+    mean_diff = diff.mean().item()
+    # Reference magnitude as the denominator for "is this diff a lot?": a diff
+    # of 0.1 on values that average 0.05 is catastrophic; on values that
+    # average 5.0 it's bf16 noise.
+    ref_abs_mean = ref_valid.abs().mean().item()
 
     if max_diff <= _VERIFY_ATOL:
         logger.error(
-            "[VERIFY key=%s] OK  n_check=%d  max_diff=%.4f", key, n_check, max_diff
+            "[VERIFY key=%s] OK  n_check=%d max_diff=%.5f mean_diff=%.5f "
+            "ref_abs_mean=%.5f",
+            key,
+            n_check,
+            max_diff,
+            mean_diff,
+            ref_abs_mean,
         )
         return
 
     row_max = diff.max(dim=1).values
     bad_rows = (row_max > _VERIFY_ATOL).nonzero(as_tuple=True)[0]
     logger.error(
-        "[VERIFY key=%s] FAIL n_check=%d bad_rows=%d max_diff=%.4f atol=%.4f",
+        "[VERIFY key=%s] FAIL n_check=%d bad_rows=%d max_diff=%.5f "
+        "mean_diff=%.5f ref_abs_mean=%.5f atol=%.4f",
         key,
         n_check,
         bad_rows.numel(),
         max_diff,
+        mean_diff,
+        ref_abs_mean,
         _VERIFY_ATOL,
     )
 
