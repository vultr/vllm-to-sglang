+    # the per-expert bucket range), which the align kernel's per-expert
+    # counter drops on the floor; the align kernel's sorted_token_ids
+    # padding fill (= num_valid_tokens) is exactly the value the Triton
+    # GEMM's mask catches, so no further special-casing is needed.
     ep_mode = num_local_tokens is not None
     align_experts = expert_mask.numel() if expert_mask is not None else num_experts
 
@@ -267,25 +276,32 @@ def triton_mxfp4_moe(
     )
 
     if ep_mode:
-        # Fills sorted_token_ids / expert_ids / num_valid_ids and zeroes
-        # moe_buf; no sentinel fill_ needed. moe_buf reuses ws.output (same
-        # [M, hidden_dim] shape) since ws.output is fully overwritten by the
-        # final reduce below.
-        _moe_sorting_fwd(
-            topk_ids,
-            topk_weights,
-            ws.sorted_token_ids,
-            ws.sorted_weights,
-            ws.expert_ids,
-            ws.num_valid_ids,
-            ws.output,
-            align_experts,
-            _BLOCK_M,
-            expert_mask,
-            num_local_tokens,
-            0,
+        # Build the global->local id table from expert_mask. cumsum(0)-1
+        # gives the local index at each local position; entries where
+        # expert_mask == 0 are non-local and get the bucket-out-of-range
+        # sentinel ``num_experts`` instead. expert_mask is int32 (see
+        # MoriEPMoE.__init__ in ep_moe/layer.py) so the cumsum result
+        # matches ws.local_hash's int32 dtype without an explicit cast.
+        torch.cumsum(expert_mask, 0, out=ws.local_hash)
+        ws.local_hash.sub_(1)
+        ws.local_hash.masked_fill_(expert_mask == 0, num_experts)
