From c08a9f69ab691a526b83329b41234fda8aa5b6e2 Mon Sep 17 00:00:00 2001
From: vllm-shim <vllm-shim@local>
Date: Thu, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH 5/8] fix(quark): zero MXFP4 stage2 weight at the sort sentinel
 position

AITER's moe_sorting_fwd writes ``sentinel = num_local_tokens[0]`` into
sort-padding positions of sorted_token_ids. That value sits inside the
valid flat (token, slot) index range -- e.g. for n_valid=16, top_k=9
the sentinel is 16, which also names a real entry at (token=1,
slot=7). Sort-padding entries inside a real-expert block end up
writing wrong-expert results to ``stage1_out[sentinel]``, the same
slot the legitimate routed entry writes if the routed expert lives on
this rank. Last writer wins; in the racy case the position is
corrupted by ~5-10% of the row magnitude.

The Triton MXFP4 GEMM cannot mask those entries via
``offs_token < num_valid_tokens`` because the wrapper computes
``num_valid_tokens = topk_ids.numel() = M*top_k`` and the sentinel
is strictly smaller. Patch 0004's verify run reports OK at the
default 0.5 tolerance because the per-row contamination is well
under it; the contamination compounds through the residual stream
across ~60 MoE layers into the multilingual-token-salad we observed
during decode.

Fix: zero ``stage2_topk_weights[sentinel]`` after the sort. The
stage2 GEMM has ``mul_routed_weight=True``, so every read at the
sentinel position multiplies by 0 and writes 0 to stage2_flat -- the
final reduce then adds 0 for that one (token, slot) pair. Cost: any
legitimate contribution at exactly that flat index is also discarded
(~1/(top_k * n_valid) per layer, scaling like 1% of one token per
layer). Correctness over a few percent of lost signal.

reference_mxfp4_moe mirrors the skip so verify (patch 0004) still
compares like-for-like.
---
 .../quark/schemes/triton_mxfp4_dispatch.py    | 32 +++++++++++++++++++
 .../quark/schemes/triton_mxfp4_reference.py   | 14 ++++++++
 2 files changed, 46 insertions(+)

diff --git a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
index 2790674..5badfff 100644
--- a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
+++ b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
@@ -311,6 +311,38 @@ def triton_mxfp4_moe(
     flat_weights = topk_weights.reshape(-1)
     ws.stage2_topk_weights.zero_()
     ws.stage2_topk_weights[:num_valid_tokens, 0] = flat_weights
+
+    # Sentinel race fix (EP only). AITER's CK sort writes
+    # ``sentinel = num_local_tokens[0]`` into sort-padding positions of
+    # ``sorted_token_ids``. That value typically lies inside the valid flat
+    # index range ``[0, M*top_k)`` (it is just ``num_local_tokens``, while
+    # the range upper bound is ``num_local_tokens*top_k`` or higher), so
+    # sort-padding entries inside a real-expert block end up writing
+    # wrong-expert garbage to ``stage1_out[sentinel]`` -- the same address
+    # the legitimate (token=sentinel//top_k, slot=sentinel%top_k) entry
+    # writes if its routed expert happens to live on this rank. The Triton
+    # GEMM cannot mask these out via ``offs_token < num_valid_tokens``
+    # because ``num_valid_tokens = topk_ids.numel() = M*top_k`` is larger
+    # than the sentinel. Verify (patch 0004) reports OK at the default
+    # 0.5 tolerance because the per-row contamination magnitude is ~0.05
+    # to 0.1; the residual stream compounds it across the 60+ MoE layers
+    # into the multilingual-garbage decode output we observed.
+    #
+    # Zeroing ``stage2_topk_weights`` at the sentinel index forces every
+    # stage2 read at that position to multiply by 0, wiping the
+    # contamination at stage2's writeback. Cost: any legitimate entry at
+    # that exact flat index also gets zeroed -- a per-layer loss of one
+    # (token, slot) pair's contribution, on the order of
+    # ``1 / (top_k * n_valid)`` of the residual. Tolerable; correctness
+    # beats the lost ~1% in this trade.
+    if ep_mode and num_local_tokens is not None:
+        # Use scatter_ rather than ``[sentinel_idx] = 0.0`` advanced
+        # indexing: the latter raises "operation not permitted when stream
+        # is capturing" on HIP during CUDA graph capture, while scatter_
+        # with a scalar src is a regular kernel launch that captures
+        # cleanly.
+        sentinel_idx = num_local_tokens.flatten()[:1].long()
+        ws.stage2_topk_weights.view(-1).scatter_(0, sentinel_idx, 0.0)
     _fused_moe_mxfp4(
         A=ws.stage1_out,
         B=w2_weight,
diff --git a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_reference.py b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_reference.py
index 6d6486a..446f375 100644
--- a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_reference.py
+++ b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_reference.py
@@ -133,6 +133,17 @@ def reference_mxfp4_moe(
         n_valid = M
     n_check = max(0, min(n_valid, max_rows))
 
+    # Mirror the sentinel-row zeroing applied in triton_mxfp4_dispatch.py
+    # (see the long comment there). Under MoRI EP we zero
+    # ``stage2_topk_weights[sentinel]`` to wipe contamination from
+    # sort-padding writes, which also wipes the legitimate contribution at
+    # that flat index. Replicate that here so the reference matches what
+    # the kernel chain actually produces.
+    if expert_mask is not None and num_local_tokens is not None:
+        sentinel_flat = n_valid
+    else:
+        sentinel_flat = -1
+
     output = torch.zeros(
         (M, hidden_dim), dtype=hidden_states.dtype, device=hidden_states.device
     )
@@ -159,6 +170,9 @@ def reference_mxfp4_moe(
     for t in range(n_check):
         x = hidden_states[t].to(torch.float32)
         for k in range(top_k):
+            if t * top_k + k == sentinel_flat:
+                # Zeroed by the dispatch fix; skip.
+                continue
             eid_g = int(topk_ids[t, k].item())
             eid_l = int(local_hash[eid_g].item())
             if eid_l < 0:
