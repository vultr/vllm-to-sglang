From 607a505fd4c99272234a9274c46ff81900f6b9af Mon Sep 17 00:00:00 2001
From: vllm-shim <vllm-shim@local>
Date: Thu, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH 5/5] fix(quark): stop caching MXFP4 MoE output buffer across
 layers

The triton_mxfp4_moe workspace cache stored `output` (the [M, hidden]
final reduce target) alongside the intermediate scratch tensors. Every
MoE layer in the model has the same shape -> same cache key -> the
same physical output tensor.

That tensor is the return value handed to dispatcher.combine, which
MoRI reads on its async comm stream. While that read is in flight, the
next layer's run_moe_core starts on the compute stream and calls
moe_sorting_fwd, which zeroes `output` (as its moe_buf arg) before any
sync with the comm stream. The combine ends up reading whatever the
new layer is writing -> garbage routed back to the originating rank,
poisoning subsequent decode steps via the KV cache.

The Triton-vs-torch verify harness (patch 0004) reports OK across all
DPs (max_diff well under tolerance), confirming the kernel math is
right; the race only manifests when MoRI combine runs asynchronously,
which the verify path doesn't exercise (it runs in eager warmup with
no comm stream in flight).

AITER's fused_moe doesn't have this problem because it does
`moe_buf = torch.empty((M, model_dim), ...)` fresh on every call.
Match that here: leave the intermediate scratch (stage1_out,
stage2_out, sorted_ids, scales, etc.) in the workspace cache, but
allocate `output` fresh per call. The extra alloc is one [M, hidden]
torch.empty per MoE layer per forward; trivial vs the GEMM cost.
---
 .../quark/schemes/triton_mxfp4_dispatch.py    | 33 ++++++++++++++-----
 1 file changed, 24 insertions(+), 9 deletions(-)

diff --git a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
index 2790674..b510ce5 100644
--- a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
+++ b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
@@ -159,7 +159,15 @@ def _get_workspace(
         stage2_topk_weights=torch.empty(
             max_padded, 1, dtype=torch.float32, device=device
         ),
-        output=torch.empty(M, hidden_dim, dtype=dtype, device=device),
+        # Note: the final `output` tensor is intentionally NOT cached here. It
+        # is the return value of triton_mxfp4_moe and gets handed to
+        # dispatcher.combine, which reads it on MoRI's async comm stream. If
+        # we reused the same buffer across MoE layers (all layers in this
+        # model share the same shape, so the same workspace key, so the same
+        # buffer) the next layer's moe_sorting_fwd would zero+overwrite the
+        # output before the previous layer's combine drained it. AITER's
+        # fused_moe sidesteps this by allocating a fresh moe_buf per call;
+        # we do the same in triton_mxfp4_moe below.
         # MoRI EP path only: moe_sorting_fwd output buffers. sorted_weights
         # is a required output slot the Triton GEMM does not consume;
         # num_valid_ids[0] is the post-padding token count that feeds the
@@ -260,11 +268,18 @@ def triton_mxfp4_moe(
         ep_mode,
     )
 
+    # Fresh `output` per call; intentionally not in the workspace cache. See
+    # the comment in _get_workspace for the aliasing race that caching it
+    # caused (MoRI combine reads the previous layer's output on an async comm
+    # stream while the next layer's moe_sorting_fwd zeros and overwrites the
+    # shared buffer).
+    output = torch.empty((M, hidden_dim), dtype=dtype, device=device)
+
     if ep_mode:
-        # Fills sorted_token_ids / expert_ids / num_valid_ids and zeroes
-        # moe_buf; no sentinel fill_ needed. moe_buf reuses ws.output (same
-        # [M, hidden_dim] shape) since ws.output is fully overwritten by the
-        # final reduce below.
+        # moe_sorting_fwd fills sorted_token_ids / expert_ids / num_valid_ids
+        # and zeroes its `moe_buf` argument; we pass the fresh `output`
+        # tensor since it has the right [M, hidden_dim] shape and gets fully
+        # overwritten by the final reduce below.
         _moe_sorting_fwd(
             topk_ids,
             topk_weights,
@@ -272,7 +287,7 @@ def triton_mxfp4_moe(
             ws.sorted_weights,
             ws.expert_ids,
             ws.num_valid_ids,
-            ws.output,
+            output,
             align_experts,
             _BLOCK_M,
             expert_mask,
@@ -334,11 +349,11 @@ def triton_mxfp4_moe(
 
     stage2_flat = ws.stage2_out.squeeze(0)
     valid_out = stage2_flat[:num_valid_tokens].view(M, top_k, hidden_dim)
-    torch.sum(valid_out, dim=1, out=ws.output)
+    torch.sum(valid_out, dim=1, out=output)
 
     if _VERIFY:
         _maybe_verify(
-            ws.output,
+            output,
             hidden_states,
             w13_weight,
             w2_weight,
@@ -351,7 +366,7 @@ def triton_mxfp4_moe(
             (M, top_k, num_experts, align_experts, ep_mode),
         )
 
-    return ws.output
+    return output
 
 
 def _is_capturing() -> bool:
