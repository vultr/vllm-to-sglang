From 1d3d0a7c56aa6564e9f2d6696338e777a4292c23 Mon Sep 17 00:00:00 2001
From: vllm-shim <vllm-shim@local>
Date: Thu, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH 1/2] mori-ep-mxfp4-triton
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

vllm-shim local patch: route MoRI EP Quark MXFP4 MoE through AITER's
Triton kernels on gfx942 (MI300X). Companion to
`quark-mxfp4-triton-gfx942.patch`, which covers the non-EP path; this
one is opt-in via `SGLANG_MORI_MXFP4_TRITON=1` so the EP integration
can be staged in after non-EP is validated.

`MoriEPMoE.run_moe_core` currently calls `aiter.fused_moe.fused_moe(...)`
unconditionally for the `is_quark_w4a4` path. On gfx942 that dispatcher
either routes to a CK kernel that doesn't exist for this arch or aborts
in the FP4 activation quant; both are the same blocker the non-EP fix
addresses. Here we intercept that branch when:

    SGLANG_MORI_MXFP4_TRITON=1 AND dispatch_a1 is not FP4

and call `triton_mxfp4_moe(...)` instead, wrapping the result in
`MoriEPNormalCombineInput` / `MoriEPLLCombineInput` to match the
dispatcher's expectations. The branch returns directly, bypassing the
subsequent `fused_moe(...)` call.

Two prerequisites the operator must satisfy:

1. `SGLANG_MORI_DISPATCH_DTYPE=bf16` — the Triton kernels take BF16
   activations. The default FP4 dispatch dtype is what triggered the
   original `dynamic_per_group_scaled_quant_fp4` abort; even if that
   were fixed, the Triton kernels' `swizzle_mx_a=False` path expects
   plain BF16 input. We detect the wrong dtype (FP4 still in
   `dispatch_a1`) and fall through to the existing fused_moe path
   rather than silently mishandle it.

2. `SGLANG_MORI_MXFP4_TRITON=1` — explicit opt-in. With the env var
   unset, this patch is a no-op and MoriEPMoE behavior is identical
   to upstream.

Known gaps the operator should be aware of:

- The Triton dispatch shim's CUDA-graph workspace cache keys on the
  input `M` dimension. In EP mode `dispatch_a1.shape[0]` varies per
  batch as `dispatch_recv_token_num` changes, so the cache won't hit
  on subsequent calls and a new workspace allocation happens per
  unique batch size. This is a perf opportunity, not a correctness
  issue, and only matters if you're capturing many distinct M values.

- The Triton kernels process all rows of `dispatch_a1` including the
  padding rows after `dispatch_recv_token_num`. MoRI combine then
  truncates back to `dispatch_recv_token_num` so output is correct;
  the wasted compute is bounded by `mori_moe_max_input_tokens`.

- `dispatch_ids.shape` and `dispatch_weights.shape` are assumed to
  match what the Triton kernels expect (`(M, top_k)`). If MoRI's
  dispatcher flattens these to 1D you'll see a shape error at the
  `top_k = topk_ids.shape[1]` line in triton_mxfp4_moe; that surfaces
  as a Python exception, not silent corruption.

Adapted from prior MXFP4 + MI300X work (non-EP path); no upstream PR.
---
 python/sglang/srt/layers/moe/ep_moe/layer.py | 52 ++++++++++++++++++++
 1 file changed, 52 insertions(+)

diff --git a/python/sglang/srt/layers/moe/ep_moe/layer.py b/python/sglang/srt/layers/moe/ep_moe/layer.py
index f201d45..fbee246 100644
--- a/python/sglang/srt/layers/moe/ep_moe/layer.py
+++ b/python/sglang/srt/layers/moe/ep_moe/layer.py
@@ -53,6 +53,17 @@ _is_npu = is_npu()
 _is_fp8_fnuz = is_fp8_fnuz()
 _use_aiter = get_bool_env_var("SGLANG_USE_AITER") and _is_hip
 
+# MoRI EP MXFP4 Triton fallback. Opt-in via SGLANG_MORI_MXFP4_TRITON=1;
+# bypasses AITER's fused_moe -> CK on gfx942 inside MoRI dispatch and
+# calls the Triton MXFP4 kernels (companion to the non-EP fallback in
+# quark_w4a4_mxfp4_moe.py). Requires SGLANG_MORI_DISPATCH_DTYPE=bf16:
+# the Triton path takes BF16 activations and cannot consume FP4-dispatch
+# tensors. We gate the import lazily so non-MXFP4 setups never pay the
+# Triton load cost.
+_use_mori_mxfp4_triton = (
+    _use_aiter and get_bool_env_var("SGLANG_MORI_MXFP4_TRITON")
+)
+
 if _use_aiter:
     from aiter import ActivationType, QuantType
     from aiter.fused_moe import fused_moe
@@ -738,6 +749,47 @@ class MoriEPMoE(DeepEPMoE):
                 quant_type = QuantType.per_1x32
 
         if is_quark_w4a4:
+            # gfx942 MoRI EP MXFP4 Triton fallback (opt-in via
+            # SGLANG_MORI_MXFP4_TRITON=1). Routes dispatch outputs into
+            # the Triton MXFP4 kernels instead of AITER's CK fused_moe.
+            # Requires BF16 dispatch (SGLANG_MORI_DISPATCH_DTYPE=bf16);
+            # if the dispatcher handed us FP4 tensors we fall through to
+            # the existing fused_moe path and let it surface the failure
+            # rather than silently mishandling the dtype here.
+            if (
+                _use_mori_mxfp4_triton
+                and dispatch_a1.dtype != torch.float4_e2m1fn_x2
+            ):
+                from sglang.srt.layers.quantization.quark.schemes.triton_mxfp4_dispatch import (
+                    triton_mxfp4_moe,
+                )
+
+                triton_out = triton_mxfp4_moe(
+                    hidden_states=dispatch_a1,
+                    w13_weight=self.w13_weight,
+                    w2_weight=self.w2_weight,
+                    w13_weight_scale=self.w13_weight_scale,
+                    w2_weight_scale=self.w2_weight_scale,
+                    topk_weights=dispatch_weights,
+                    topk_ids=dispatch_ids,
+                )
+                from sglang.srt.layers.moe.token_dispatcher import (
+                    DispatchOutputChecker,
+                )
+
+                combine_input_wrapper = (
+                    MoriEPNormalCombineInput
+                    if DispatchOutputChecker.format_is_deepep_normal(
+                        dispatch_output
+                    )
+                    else MoriEPLLCombineInput
+                )
+                return combine_input_wrapper(
+                    hidden_states=triton_out,
+                    topk_ids=dispatch_output.origin_topk_ids,
+                    topk_weights=dispatch_output.origin_topk_weights,
+                )
+
             if hasattr(torch, "float4_e2m1fn_x2"):
                 w13_weight = self.w13_weight.view(torch.float4_e2m1fn_x2)
                 w2_weight = self.w2_weight.view(torch.float4_e2m1fn_x2)
