From d002d63536265f825774d14459b4f9bc24fc75c2 Mon Sep 17 00:00:00 2001
From: vllm-shim <vllm-shim@local>
Date: Thu, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH 7/7] debug(quark): dump moe_sorting_fwd outputs to localize EP
 zero-output

The verify pattern shows triton output is identically zero across most
DPs (mean_diff == ref_abs_mean exactly, only achievable when triton == 0
for every row). One DP shows triton output ~3x the reference magnitude
with sign mismatches. Both signatures are consistent with the kernel
indexing OOB into our local w13/w2 tensors -- which only happens if
moe_sorting_fwd is writing GLOBAL expert ids (range 0..align_experts)
into expert_ids while our Triton GEMM expects LOCAL ids (0..49 for the
MoRI EP=8 / 392-global config).

Add a one-shot post-sort diagnostic gated on VLLM_SHIM_MXFP4_VERIFY=1
(rides the existing verify warmup pass) that dumps:
  - num_local_tokens raw value
  - num_valid_ids written by moe_sorting (the post-padding token count)
  - expert_ids stats (min, max, count of -1, count in local range,
    count above local range)
  - expert_ids[:32] and sorted_token_ids[:32] raw values

If expert_ids max > num_experts_local, we have our smoking gun and
need an explicit global->local remap in the dispatch wrapper.
---
 .../quark/schemes/triton_mxfp4_dispatch.py    | 86 +++++++++++++++++++
 1 file changed, 86 insertions(+)

diff --git a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
index 9a13f37..7ddd866 100644
--- a/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
+++ b/python/sglang/srt/layers/quantization/quark/schemes/triton_mxfp4_dispatch.py
@@ -286,6 +286,33 @@ def triton_mxfp4_moe(
             0,
         )
         num_tokens_post_padded = ws.num_valid_ids[:1]
+
+        # One-shot post-sort diagnostic: dump enough state to tell whether
+        # moe_sorting_fwd is emitting LOCAL expert ids (0..num_local-1, which
+        # is what the Triton GEMM needs to index our local w13/w2 weights) or
+        # GLOBAL ids (0..align_experts-1, which would OOB our local tensors
+        # and produce zero/garbage outputs). Gated by VLLM_SHIM_MXFP4_VERIFY=1
+        # to ride alongside the existing verify harness so we get the dump
+        # on the same warmup pass that runs the reference.
+        if _VERIFY and not _is_capturing():
+            sort_key = (
+                "sort",
+                num_experts,
+                align_experts,
+                M,
+                top_k,
+            )
+            if sort_key not in _verified_keys:
+                _verified_keys.add(sort_key)
+                _log_sort_dump(
+                    ws.sorted_token_ids,
+                    ws.expert_ids,
+                    ws.num_valid_ids,
+                    expert_mask,
+                    num_local_tokens,
+                    num_experts,
+                    align_experts,
+                )
     else:
         ws.sorted_token_ids.fill_(num_valid_tokens)
         _moe_align_block_size_capture_safe(topk_ids, num_experts, _BLOCK_M, ws)
@@ -403,6 +430,65 @@ def _is_capturing() -> bool:
         return False
 
 
+def _log_sort_dump(
+    sorted_token_ids: torch.Tensor,
+    expert_ids: torch.Tensor,
+    num_valid_ids: torch.Tensor,
+    expert_mask: torch.Tensor,
+    num_local_tokens: torch.Tensor,
+    num_experts_local: int,
+    align_experts: int,
+) -> None:
+    """Diagnostic dump after moe_sorting_fwd to tell global vs local ids apart.
+
+    Triton GEMM indexes our LOCAL w13/w2 weights via expert_ids[block]. If
+    moe_sorting_fwd is emitting global ids (range 0..align_experts) instead
+    of local (0..num_experts_local), every block points OOB for our tensors
+    and the kernel reads zeros/garbage. The verify pattern (triton ~ 0 on
+    most DPs, ~3x ref on one) is the smoking gun for OOB reads.
+    """
+    try:
+        eid = expert_ids.detach().to("cpu")
+        sti = sorted_token_ids.detach().to("cpu")
+        nvi = num_valid_ids.detach().to("cpu").tolist()
+        nlt = num_local_tokens.detach().flatten().to("cpu").tolist()
+        em_sum = int(expert_mask.detach().to("cpu").sum().item())
+
+        eid_min = int(eid.min().item())
+        eid_max = int(eid.max().item())
+        eid_neg = int((eid < 0).sum().item())
+        eid_in_local = int(((eid >= 0) & (eid < num_experts_local)).sum().item())
+        eid_above_local = int((eid >= num_experts_local).sum().item())
+
+        logger.error(
+            "[SORT-DUMP] num_local=%s num_valid_ids=%s align_experts=%d "
+            "num_experts_local=%d expert_mask_sum=%d",
+            nlt,
+            nvi,
+            align_experts,
+            num_experts_local,
+            em_sum,
+        )
+        logger.error(
+            "[SORT-DUMP] expert_ids stats: min=%d max=%d count_neg=%d "
+            "count_in_local_range=%d count_above_local=%d (total=%d)",
+            eid_min,
+            eid_max,
+            eid_neg,
+            eid_in_local,
+            eid_above_local,
+            eid.numel(),
+        )
+        logger.error(
+            "[SORT-DUMP] expert_ids[:32]: %s", eid[:32].tolist()
+        )
+        logger.error(
+            "[SORT-DUMP] sorted_token_ids[:32]: %s", sti[:32].tolist()
+        )
+    except Exception as e:  # noqa: BLE001
+        logger.error("[SORT-DUMP] failed: %r", e)
+
+
 def _maybe_verify(
     triton_out: torch.Tensor,
     hidden_states: torch.Tensor,
