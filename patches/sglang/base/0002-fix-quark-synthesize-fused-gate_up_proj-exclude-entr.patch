From c81189d4020a3dc60f72e8a1e1a4955fed359217 Mon Sep 17 00:00:00 2001
From: vllm-shim <vllm-shim@local>
Date: Thu, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH 2/2] fix(quark): synthesize fused gate_up_proj exclude entries
 from HF names

SGLang fuses gate_proj + up_proj into a single gate_up_proj linear
at model build, but Quark checkpoints (Kimi K2.6 MXFP4 etc.) ship
their "exclude" list using the original HF unfused names. Without
synthesizing the fused names here, layers the checkpoint marks as
quantization-skipped (MoE expert gate/up, NextN eh_proj, etc.) fall
back to the quantized path because `should_ignore_layer(prefix,
ignore=self.exclude_layers, ...)` sees no matching name and returns
False. Result on the user side is either silent garbage output or a
load-time shape error depending on the layer.

Patched in QuarkConfig.from_config -- the only construction site
that resolves the exclude list -- so the synthesis runs once at
model init and downstream call sites stay unchanged. Deduped via
dict.fromkeys so configs that already include the fused names see
no duplicates.

Adapted from prior MXFP4 + MI300X work; not upstreamed.
---
 .../sglang/srt/layers/quantization/quark/quark.py   | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/python/sglang/srt/layers/quantization/quark/quark.py b/python/sglang/srt/layers/quantization/quark/quark.py
index ad3546a..954c17b 100644
--- a/python/sglang/srt/layers/quantization/quark/quark.py
+++ b/python/sglang/srt/layers/quantization/quark/quark.py
@@ -163,6 +163,19 @@ class QuarkConfig(QuantizationConfig):
             q_proj_q_config = cast(dict[str, Any], layer_quant_config.get("*q_proj"))
             if q_proj_q_config is not None:
                 q_proj_q_config["output_tensors"] = None
+        # Synthesize fused exclude entries: SGLang fuses gate_proj+up_proj
+        # into gate_up_proj at model build, but Quark exclude lists use HF
+        # unfused names. Without this synthesis the fused linear escapes
+        # the exclude list and gets quantized despite the checkpoint asking
+        # for it to stay in BF16.
+        excludes = cast(list[str], config.get("exclude", []))
+        additions: list[str] = []
+        for e in excludes:
+            if ".gate_proj" in e:
+                additions.append(e.replace(".gate_proj", ".gate_up_proj"))
+            if ".up_proj" in e:
+                additions.append(e.replace(".up_proj", ".gate_up_proj"))
+        config["exclude"] = list(dict.fromkeys(excludes + additions))
 
         return cls(
             quant_config=config,
